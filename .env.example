# 06-VLM-Gemini-Vision 环境变量示例
# 用法：复制为 .env 并填入真实值；或直接 export 到 shell 环境。
# 切勿把真实密钥/内网 IP 提交进仓库（vlm_config.json 已改为占位）。

# VLM / OpenAI 兼容代理地址（示例为本机 cli-proxy）
VLM_API_BASE=http://localhost:8317/v1

# VLM API 密钥（占位符，请替换为你自己的、并优先用环境变量而非文件）
VLM_API_KEY=replace-with-your-own-key

# 模型名
VLM_MODEL=gemini-3-pro-preview

# 网络超时（秒）与最大重试次数
VLM_API_TIMEOUT=30
VLM_API_MAX_RETRIES=2

# MuJoCo PAROL6 模型路径（可选，默认使用 11.1 仓库内 parol6_fixed.xml）
# PAROL6_MODEL_PATH=/abs/path/to/parol6_fixed.xml
